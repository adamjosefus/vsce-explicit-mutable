{
  "name": "explicit-mutable",
  "displayName": "Explicit Mutable",
  "version": "1.1.0",
  "description": "Warns on unannotated mutable types in TypeScript files.",
  "categories": [
    "Linters"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adamjosefus/vsce-explicit-mutable.git"
  },
  "publisher": "adamjosefus",
  "main": "./out/extension.js",
  "scripts": {
    "bundle": "node esbuild.mjs",
    "compile": "tsc --noEmit",
    "fmt": "biome check . --error-on-warnings",
    "fmt:write": "biome check . --write --error-on-warnings",
    "package": "pnpm compile && vsce package --no-dependencies",
    "prepare": "husky",
    "test": "vitest run",
    "vscode:prepublish": "npm run bundle",
    "watch": "node esbuild.mjs --watch"
  },
  "contributes": {
    "configuration": {
      "title": "Explicit Mutable",
      "properties": {
        "explicit-mutable.enable.ts": {
          "type": "boolean",
          "default": true,
          "description": "Enable linting for TypeScript files (.ts, .mts, .cts)."
        },
        "explicit-mutable.enable.tsx": {
          "type": "boolean",
          "default": true,
          "description": "Enable linting for TSX files (.tsx, .mtsx, .ctsx)."
        },
        "explicit-mutable.enable.declarations": {
          "type": "boolean",
          "default": true,
          "description": "Enable linting for declaration files (.d.ts, .d.mts, .d.cts, .d.tsx, .d.mtsx, .d.ctsx)."
        },
        "explicit-mutable.ignoreNodeModules": {
          "type": "boolean",
          "default": true,
          "description": "Ignore files inside node_modules."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "icon": "icon.png"
}